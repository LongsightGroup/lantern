{
  "tasks": {
    "dev": "deno run --unsafely-ignore-certificate-errors --watch --allow-read --allow-write --allow-env --allow-net main.ts",
    "start": "deno run --allow-read --allow-write --allow-env --allow-net main.ts",
    "db:migrate": "deno run --allow-read --allow-env --allow-net src/db/migrate.ts",
    "app:validate": "deno run --allow-read tools/app_validate.ts",
    "app:preview": "deno run --allow-read --allow-net tools/app_preview.ts",
    "local:init": "deno run --allow-read --allow-write tools/local_init.ts",
    "local:migrate": "deno run --env-file=.env.local --allow-read --allow-env --allow-net src/db/migrate.ts",
    "local:seed": "deno run --env-file=.env.local --allow-read --allow-write --allow-env --allow-net tools/local_seed.ts",
    "local:bootstrap": "deno task local:seed",
    "local:start": "deno run --env-file=.env.local --allow-read --allow-write --allow-env --allow-net main.ts",
    "local:dev": "deno run --env-file=.env.local --watch --allow-read --allow-write --allow-env --allow-net main.ts",
    "build:worker": "deno bundle --platform=browser src/worker.ts -o output/worker.bundle.mjs",
    "check:worker": "deno task build:worker && deno run --allow-read tools/check_worker_bundle.ts",
    "fmt": "deno run -A npm:oxfmt@0.43.0 --write .",
    "fmt:check": "deno run -A npm:oxfmt@0.43.0 --check .",
    "lint": "deno run -A npm:oxlint@1.58.0",
    "check": "deno check main.ts src/**/*.ts sdk/**/*.ts tools/*.ts",
    "test": "deno test --allow-read --allow-write --allow-env --allow-net",
    "validate": "deno task fmt:check && deno task lint && deno task check && deno task check:worker && deno test --allow-read --allow-write --allow-env --allow-net"
  },
  "imports": {
    "@ajv2020": "npm:ajv@8.18.0/dist/2020.js",
    "@db/postgres": "./src/db/postgres.ts",
    "@hono/hono": "jsr:@hono/hono@^4.10.1",
    "@std/assert": "jsr:@std/assert@^1.0.15",
    "@std/semver": "jsr:@std/semver@1.0.8",
    "jose": "npm:jose@6.2.2",
    "oauth4webapi": "npm:oauth4webapi@3.8.5",
    "postgres": "npm:postgres@3.4.7"
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true
  }
}
