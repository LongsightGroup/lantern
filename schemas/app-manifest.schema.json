{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/app-manifest.schema.json",
  "title": "Gateway App Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "app_id",
    "version",
    "title",
    "owner",
    "entrypoint",
    "capabilities",
    "roles",
    "grading"
  ],
  "properties": {
    "schema_version": {
      "const": "1"
    },
    "app_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "minLength": 3,
      "maxLength": 64
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][A-Za-z0-9.-]+)?$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "description": {
      "type": "string",
      "maxLength": 500
    },
    "owner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {
          "const": "user"
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      }
    },
    "entrypoint": {
      "type": "string",
      "pattern": "^/dist/.+\\.html$"
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": ["learner", "instructor"]
      }
    },
    "install_scope": {
      "enum": ["course", "assignment"],
      "default": "course"
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "read_launch_context",
          "read_activity_content",
          "submit_attempt_event",
          "submit_evidence_artifact",
          "finalize_attempt",
          "read_local_state",
          "write_local_state"
        ]
      }
    },
    "grading": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": {
          "enum": ["declarative", "manual", "completion", "browser"]
        },
        "rubric_file": {
          "type": "string",
          "pattern": "^/scoring/.+\\.json$"
        },
        "max_score": {
          "type": "number",
          "minimum": 0
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "declarative"
              }
            },
            "required": ["mode"]
          },
          "then": {
            "required": ["rubric_file", "max_score"]
          }
        },
        {
          "if": {
            "properties": {
              "mode": {
                "const": "browser"
              }
            },
            "required": ["mode"]
          },
          "then": {
            "required": ["max_score"]
          }
        }
      ]
    },
    "browser": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fullscreen": {
          "type": "boolean"
        },
        "clipboard_write": {
          "type": "boolean"
        }
      }
    },
    "content_files": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^/content/.+"
      }
    },
    "preview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fixtures_file", "tests_file"],
      "properties": {
        "fixtures_file": {
          "type": "string",
          "pattern": "^/preview/.+\\.json$"
        },
        "tests_file": {
          "type": "string",
          "pattern": "^/preview/.+\\.json$"
        }
      }
    },
    "authoring": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "grader_spec_files", "evidence_example_file"],
      "properties": {
        "kind": {
          "const": "browser_autograder"
        },
        "grader_spec_files": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^/grading/.+\\.js$"
          }
        },
        "evidence_example_file": {
          "type": "string",
          "pattern": "^/evidence/.+\\.json$"
        }
      }
    },
    "icon": {
      "type": "string",
      "pattern": "^/.+"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "capabilities": {
            "type": "array",
            "contains": {
              "const": "submit_evidence_artifact"
            }
          }
        },
        "required": ["capabilities"]
      },
      "then": {
        "properties": {
          "capabilities": {
            "type": "array",
            "contains": {
              "const": "finalize_attempt"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "grading": {
            "type": "object",
            "properties": {
              "mode": {
                "const": "browser"
              }
            },
            "required": ["mode"]
          }
        },
        "required": ["grading"]
      },
      "then": {
        "required": ["authoring"],
        "properties": {
          "authoring": {
            "type": "object",
            "required": ["kind", "grader_spec_files", "evidence_example_file"],
            "properties": {
              "kind": {
                "const": "browser_autograder"
              },
              "grader_spec_files": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "pattern": "^/grading/.+\\.js$"
                }
              },
              "evidence_example_file": {
                "type": "string",
                "pattern": "^/evidence/.+\\.json$"
              }
            }
          }
        }
      }
    }
  ]
}
